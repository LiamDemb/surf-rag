# Required Open AI API key
OPENAI_API_KEY=sk-
OPENAI_BATCH_MAX_REQUESTS=50000

# Paths and reproducibility
SEED=42
OUTPUT_DIR=data/processed
BENCHMARK_PATH=${OUTPUT_DIR}/benchmark.jsonl
DOCSTORE_PATH=${OUTPUT_DIR}/docstore.sqlite
RESULTS_DIR=results

# Dataset paths
NQ_PATH=
2WIKI_PATH=

# Benchmark split
TRAIN_RATIO=0.8
DEV_RATIO=0.1
TEST_RATIO=0.1

# Oracle creation pipeline
ORACLE_BASE=data/oracle
# Tag used in data/oracle/<ORACLE_BENCHMARK>/...
ORACLE_BENCHMARK=mix
ORACLE_SPLIT=dev
# Directory name for this oracle run
ORACLE_RUN_ID=run1
# Same as BENCHMARK_PATH unless you use a different snapshot file
ORACLE_BENCHMARK_PATH=${BENCHMARK_PATH}
# Must contain corpus + FAISS + graph + alias_map.json for retrievers
ORACLE_RETRIEVAL_ASSET_DIR=${OUTPUT_DIR}
ORACLE_BRANCH_TOP_K=25
ORACLE_FUSION_KEEP_K=25
# Space-separated betas for sweep and label materialization (must include selected beta).
ORACLE_BETAS=0.5 1.0 2.0 5.0 10.0 20.0
ORACLE_MIN_ENTROPY_NATS=0.1
# Leave empty to use recommended beta from `recommended_beta.json` after sweep
SELECTED_BETA=

# --- Router dataset output (defaults track oracle run; override when needed) ---------------
ROUTER_DATASET_BASE=data/router
# Usually same as ORACLE_BENCHMARK
ROUTER_BENCHMARK=${ORACLE_BENCHMARK}
# Name of the router dataset run folder (e.g. same as ORACLE_RUN_ID)
ROUTER_DATASET_ID=${ORACLE_RUN_ID}
ROUTER_BENCHMARK_PATH=${BENCHMARK_PATH}
ROUTER_ORACLE_BENCHMARK=${ORACLE_BENCHMARK}
ROUTER_ORACLE_SPLIT=${ORACLE_SPLIT}
ROUTER_ORACLE_RUN_ID=${ORACLE_RUN_ID}
ORACLE_BASE_FOR_ROUTER=${ORACLE_BASE}
EMBEDDING_MODEL_FOR_ROUTER=${EMBEDDING_MODEL}

# Models (setup with make setup-models)
MODEL_NAME=all-MiniLM-L6-v2
SPACY_MODEL=en_core_web_sm
HF_HOME=${OUTPUT_DIR}/hf_cache
EMBEDDING_MODEL=all-MiniLM-L6-v2

# LLM generator
OPENAI_MODEL=gpt-4o-mini
GENERATOR_MAX_TOKENS=512
GENERATOR_BASE_PROMPT_FILE=prompts/generator.txt
# Graph RAG: when 1/true/yes, prepend graph path lines to each chunk in the prompt; default is off (chunk text only, like dense)
INCLUDE_GRAPH_PATHS_IN_PROMPT=

# LLM IE
LLM_IE_MODEL=gpt-4o-mini
LLM_IE_TEMPERATURE=0.0
LLM_IE_MAX_TOKENS=4096
LLM_IE_PROMPT_FILE=prompts/llm_ie_extraction.txt

# LLM query entity extraction
QUERY_ENTITY_MODEL=gpt-4o-mini
QUERY_ENTITY_PROMPT_FILE=prompts/query_entity_extraction.txt

# LLM-as-the-judge (legacy)
LLM_JUDGE_MODEL=gpt-4o-mini
LLM_JUDGE_TEMPERATURE=0.0


# Retrieval top candidates
PROBE_TOP_K = 25
DENSE_TOP_K=10

# GraphRAG strategy
GRAPH_TOP_K=10
GRAPH_MAX_HOPS=2
GRAPH_BIDIRECTIONAL=true
GRAPH_ENTITY_VECTOR_TOP_K=3
GRAPH_ENTITY_VECTOR_THRESHOLD=0.5
GRAPH_START_ENTITY_WEIGHT=2.0
GRAPH_EXPANDED_ENTITY_WEIGHT=1.0
GRAPH_SYNERGY_GAMMA=0.5

# Corpus building constraints
MAX_PAGES=12
MAX_HOPS=2
MAX_LIST_PAGES=2
MAX_COUNTRY_PAGES=1
CHUNK_MIN_TOKENS=500
CHUNK_MAX_TOKENS=800
CHUNK_OVERLAP_TOKENS=100