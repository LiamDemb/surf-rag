# Required Open AI API key
OPENAI_API_KEY=sk-
OPENAI_BATCH_MAX_REQUESTS=50000

# Reproducibility
SEED=42
RESULTS_DIR=results

# Data organsation
DATA_BASE=data
# Benchmark bundles: $BENCHMARK_BASE/$BENCHMARK_NAME/$BENCHMARK_ID/{benchmark,corpus,evaluations}
BENCHMARK_BASE=${DATA_BASE}/benchmarks

# Benchmark setup
BENCHMARK_NAME=mix
BENCHMARK_ID=v01

# Router setup: $ROUTER_BASE/$ROUTER_ID/{oracle,dataset,model} (default $DATA_BASE/router)
# Trained MLPs live at $DATA_BASE/router/$ROUTER_ID/model/<input_mode>/
#   e.g. .../model/both/model.pt, .../model/query-features/model.pt
ROUTER_ID=v01
ROUTER_BASE=${DATA_BASE}/router

# Raw dataset sources (for ingest)
NQ_PATH=
2WIKI_PATH=

# Router dataset stratified split
TRAIN_RATIO=0.8
DEV_RATIO=0.1
TEST_RATIO=0.1

# Derived paths
OUTPUT_DIR=${BENCHMARK_BASE}/${BENCHMARK_NAME}/${BENCHMARK_ID}/corpus
BENCHMARK_PATH=${BENCHMARK_BASE}/${BENCHMARK_NAME}/${BENCHMARK_ID}/benchmark/benchmark.jsonl
DOCSTORE_PATH=${BENCHMARK_BASE}/${BENCHMARK_NAME}/${BENCHMARK_ID}/corpus/docstore.sqlite
ORACLE_BENCHMARK_PATH=${BENCHMARK_PATH}
ORACLE_RETRIEVAL_ASSET_DIR=${BENCHMARK_BASE}/${BENCHMARK_NAME}/${BENCHMARK_ID}/corpus
ORACLE_BRANCH_TOP_K=25
ORACLE_FUSION_KEEP_K=25
ORACLE_BETAS=0.5 1.0 2.0 5.0 10.0 20.0 50.0
ORACLE_MIN_ENTROPY_NATS=0.1
# leave empty to use recommended_beta.json after sweep
SELECTED_BETA=

EMBEDDING_MODEL_FOR_ROUTER=${EMBEDDING_MODEL}

# Router MLP (train: make router-train; eval: make router-eval; ablations: make router-train-ablations, make router-evaluate-ablations)
# ROUTER_EPOCHS=100
# ROUTER_BATCH_SIZE=32
# ROUTER_LEARNING_RATE=0.001
# ROUTER_TRAIN_DEVICE=cpu
# one of: both | query-features | embedding
# ROUTER_INPUT_MODE=both
# space-separated list for *-ablations Make targets
# ROUTER_INPUT_MODES=both query-features embedding

# Overlap labelling for future eval (path to split_question_ids.json in router dataset)
# ROUTER_SPLIT_QUESTION_IDS=${DATA_BASE}/router/${ROUTER_ID}/dataset/split_question_ids.json

# Models (setup with make setup-models)
MODEL_NAME=all-MiniLM-L6-v2
SPACY_MODEL=en_core_web_sm
HF_HOME=${BENCHMARK_BASE}/${BENCHMARK_NAME}/${BENCHMARK_ID}/corpus/hf_cache
# HuggingFace transformers cache (defaults under HF_HOME if unset)
# TRANSFORMERS_CACHE=${HF_HOME}/transformers
EMBEDDING_MODEL=all-MiniLM-L6-v2
# Cross-encoder reranker (warmed by make setup-models)
# CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
# E2E learned-router embedding/feature batching (make e2e-prepare / e2e-submit)
# E2E_ROUTER_INFERENCE_BATCH_SIZE=32
# E2E reranker: none (default) or cross_encoder — warm CE with make setup-models
# E2E_RERANKER=cross_encoder
# E2E_RERANK_TOP_K=10
# E2E_CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2  # Makefile default; override in .env if needed

# LLM generator (always uses OpenAI function tool `format_answer`: reasoning + short answer)
OPENAI_MODEL=gpt-4o-mini
GENERATOR_MAX_TOKENS=512
GENERATOR_BASE_PROMPT_FILE=prompts/generator.txt
# Graph RAG: when 1/true/yes, prepend graph path lines to each chunk in the prompt; default is off (chunk text only, like dense)
INCLUDE_GRAPH_PATHS_IN_PROMPT=

# LLM IE
LLM_IE_MODEL=gpt-4o-mini
LLM_IE_TEMPERATURE=0.0
LLM_IE_MAX_TOKENS=4096
LLM_IE_PROMPT_FILE=prompts/llm_ie_extraction.txt

# LLM query entity extraction
QUERY_ENTITY_MODEL=gpt-4o-mini
QUERY_ENTITY_PROMPT_FILE=prompts/query_entity_extraction.txt

# LLM-as-the-judge (legacy)
LLM_JUDGE_MODEL=gpt-4o-mini
LLM_JUDGE_TEMPERATURE=0.0


# Retrieval top candidates
PROBE_TOP_K = 25

# GraphRAG strategy
GRAPH_MAX_HOPS=2
GRAPH_BIDIRECTIONAL=true
GRAPH_ENTITY_VECTOR_TOP_K=3
GRAPH_ENTITY_VECTOR_THRESHOLD=0.5
GRAPH_START_ENTITY_WEIGHT=2.0
GRAPH_EXPANDED_ENTITY_WEIGHT=1.0
GRAPH_SYNERGY_GAMMA=0.5

# Corpus building constraints
MAX_PAGES=12
MAX_HOPS=2
MAX_LIST_PAGES=2
MAX_COUNTRY_PAGES=1
CHUNK_MIN_TOKENS=500
CHUNK_MAX_TOKENS=800
CHUNK_OVERLAP_TOKENS=100
