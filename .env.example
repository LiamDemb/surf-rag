# Copy to .env and fill in secrets. Do not commit .env.

# Required for OpenAI batch generation and any OpenAI-calling code paths
OPENAI_API_KEY=

# Optional: local / machine-specific overrides (rare; prefer paths.hf_home in YAML)
# HF_HOME=
# TRANSFORMERS_CACHE=
# WIKIMEDIA_OAUTH2_ACCESS_TOKEN=

# --- Optional: avoid duplicate OpenMP (some macOS FAISS + PyTorch stacks)
# KMP_DUPLICATE_LIB_OK=TRUE
